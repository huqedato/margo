{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "margo",
  "outputfilename": "margo",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Quda Theo"
  },
  "info": {
    "productName": "Margo",
    "companyName": "Quda Theo",
    "copyright": "Copyright © 2026 Quda Theo",
    "productVersion": "1.0.0",
    "description": "A fast simple opinionated markdown viewer",
    "license": "MIT",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown Document",
        "iconName": "appicon",
        "role": "Viewer"
      }
    ]
  }
}
